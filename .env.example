# Copy this file to .env and fill only the free-tier keys you want to use.
# The monitor is designed to degrade gracefully when optional providers are absent.

# Optional high-frequency quote source.
FINNHUB_API_KEY=

# Optional quote and candle source.
TWELVE_DATA_API_KEY=

# Optional quote, daily candle, and news fallback.
FMP_API_KEY=

# Optional daily candle fallback.
ALPHA_VANTAGE_API_KEY=

# Optional news sentiment/context source.
MARKETAUX_API_KEY=

# Runtime defaults. CLI flags override these.
QAP_SYMBOL=SNDK
# QAP_ENV_PATH=./.env
# QAP_STATE_PATH=./state/sndk_state.json
